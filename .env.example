# FMSS Platform Configuration

# Server
NODE_ENV=development
PORT=8000
DOMAIN=localhost

# Microservice Ports (internal)
SAMS_PORT=3000
CONTRACTS_PORT=3100

# SAMS Configuration
SAMS_JWT_SECRET=your-jwt-secret-key-change-this
SAMS_DB_PATH=./data/sams.db
SAMS_EMAIL_ENABLED=false

# Contracts Configuration
CONTRACTS_DB_PATH=./data/contracts.db

# News Admin Portal (main site)
# Hidden admin route — make it non-guessable in production, e.g. /admin-7h2k9q
ADMIN_PATH=/admin
# bcrypt hash of the admin password. Generate with:
#   node scripts/hash-password.js "your-strong-password"
ADMIN_PASSWORD_HASH=
# Long random string for signing the session cookie. Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=

# Production Deployment
# NODE_ENV=production
# DOMAIN=fmss.ae
# PORT=80 (or 443 for HTTPS)
